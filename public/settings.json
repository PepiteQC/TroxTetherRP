      "enabled": false,
      "maxSpawn": 0
    }
  ],
  "ui": {
    "defaultTheme": "dark",
    "accentColor": "#7b6fff",
    "fontFamily": "system-ui",
    "monoFont": "JetBrains Mono",
    "animationsEnabled": true,
    "hudEnabled": true,
    "devConsoleKey": "F2",
    "builderKey": "B",
    "chatKey": "T",
    "escapeAction": "close_menu",
    "language": "fr-CA"
  },
  "map": {
    "enabled": true,
    "style": "satellite",
    "defaultZoom": 1.0,
    "showPlayers": true,
    "showProperties": true,
    "showVehicles": false,
    "blipTypes": [
      "player",
      "property_for_sale",
      "property_sold",
      "police",
      "ems",
      "fire",
      "gas_station",
      "mechanic",
      "bank",
      "atm",
      "casino",
      "prison"
    ]
  },
  "notifications": {
    "enabled": true,
    "maxVisible": 4,
    "durationMs": 3500,
    "positionX": "right",
    "positionY": "top",
    "types": {
      "info": {
        "color": "#4488ff",
        "icon": "ℹ️"
      },
      "success": {
        "color": "#44ff88",
        "icon": "✅"
      },
      "warning": {
        "color": "#ffaa44",
        "icon": "⚠️"
      },
      "error": {
        "color": "#ff4444",
        "icon": "❌"
      },
      "admin": {
        "color": "#7b6fff",
        "icon": "🛡️"
      }
    }
  },
  "audio": {
    "enabled": true,
    "masterVolume": 0.7,
    "sfxVolume": 0.8,
    "musicVolume": 0.3,
    "spatialAudio": true,
    "maxAudioSources": 32
  },
  "dev": {
    "hotReload": true,
    "verbosePhysics": false,
    "showBoundingBoxes": false,
    "showNavmesh": false,
    "showFPS": true,
    "showPing": true,
    "consoleEnabled": true,
    "brainDebug": false,
    "thirdEyeDebug": false
  }
