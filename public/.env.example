# ============================================================
# ETHERWORLD PLATFORM TESTER 3D — Variables d'environnement
# Copie ce fichier en ".env" et ajuste les valeurs.
# Ne JAMAIS committer le ".env" réel dans Git.
# ============================================================

# --- Environnement ---
NODE_ENV=development
# development | staging | production

# --- Serveur ---
PORT=3001
HOST=0.0.0.0
SANDBOX=true
# true = mode bac à sable (resets, pas de persistance destructive)

# --- WebSocket ---
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL_MS=15000
WS_MAX_CONNECTIONS=200

# --- Sécurité / Admin ---
ADMIN_TOKEN=change-moi-en-production
SESSION_SECRET=change-moi-aussi-stp
CORS_ORIGIN=http://localhost:5173

# --- Logger (EtherAudit) ---
LOG_LEVEL=info
# trace | debug | info | warn | error
LOG_TO_FILE=true
LOG_DIR=./logs

# --- Persistance ---
DATA_DIR=./data
WORLD_FILE=world.json
AUTOSAVE_INTERVAL_MS=60000

# --- Limites monde ---
MAX_ENTITIES=2000
MAX_PROPS_PER_PLAYER=150
TICK_RATE=30
# ticks par seconde pour la boucle physique

# --- Base de données (si applicable plus tard) ---
DATABASE_URL=
